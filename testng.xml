<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  The BrowserStack SDK reads the platforms[] list in browserstack.yml and
  re-runs this suite once per platform/device, in parallel. Cucumber's own
  scenario-level parallelism is enabled via dataprovider-thread-count so that
  multiple scenarios run concurrently within a single device session pool.
-->
<suite name="EatClub Mobile Suite" parallel="methods" data-provider-thread-count="2">
    <test name="Wikipedia Cucumber Tests">
        <classes>
            <class name="com.eatclub.runners.TestNGRunner"/>
        </classes>
    </test>
</suite>
